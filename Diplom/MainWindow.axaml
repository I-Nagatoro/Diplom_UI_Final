<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Diplom.MainWindow"
        Width="1200"
        Height="760"
        Title="Главное окно"
        Background="#0F172A"
        Icon="Assets/Icon.ico"
        WindowStartupLocation="CenterScreen">

  <Grid Margin="20">

    <!-- GUEST VIEW -->
    <Border x:Name="GuestContent"
            Background="#111827"
            CornerRadius="18"
            Padding="30"
            IsVisible="True">

      <Grid RowDefinitions="Auto,*,Auto">

        <!-- Заголовок -->
        <StackPanel Spacing="10" HorizontalAlignment="Center">
          <TextBlock Text="ПЕРЕВОДЧИК ВИДЕО"
                     FontSize="20"
                     Foreground="#38BDF8"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"/>

          <TextBlock Text="Добро пожаловать"
                     FontSize="30"
                     FontWeight="Bold"
                     Foreground="White"
                     HorizontalAlignment="Center"/>

          <TextBlock Text="Войдите в систему или зарегистрируйтесь, чтобы начать работу."
                     FontSize="15"
                     Foreground="#CBD5E1"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     MaxWidth="520"/>
        </StackPanel>

        <!-- Центр -->
        <Border Grid.Row="1"
                Background="#0F172A"
                CornerRadius="18"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="560">

          <StackPanel Spacing="20" HorizontalAlignment="Center">

            <TextBlock Text="Видео-перевод и дубляж"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Загрузка видео, обработка, контроль прогресса и просмотр результата."
                       FontSize="15"
                       Foreground="#94A3B8"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
              <Button x:Name="BtnLogin"
                      Content="Войти"
                      Click="OpenLogin"
                      Background="#059669"
                      Foreground="White"
                      Padding="14,8"
                      MinWidth="120"/>

              <Button x:Name="BtnRegister"
                      Content="Регистрация"
                      Click="OpenRegistration"
                      Background="#2563EB"
                      Foreground="White"
                      Padding="14,8"
                      MinWidth="120"/>
            </StackPanel>

          </StackPanel>
        </Border>

      </Grid>
    </Border>

    <!-- USER VIEW -->
    <Border x:Name="UserContent"
            Background="#111827"
            CornerRadius="18"
            Padding="24"
            IsVisible="False">

      <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="18">

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="14">
          <Border Width="72" Height="72" CornerRadius="36" Background="#0F172A" ClipToBounds="True">
            <Image x:Name="AvatarImage"
                   Width="72"
                   Height="72"
                   Stretch="UniformToFill"/>
          </Border>

          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Главная"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock x:Name="WelcomeText"
                       FontSize="15"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </StackPanel>

        <!-- Описание -->
        <Border Grid.Row="1" Background="#0F172A" CornerRadius="14" Padding="18">
          <TextBlock Text="Выберите сценарий работы:"
                     FontSize="15"
                     Foreground="#CBD5E1"/>
        </Border>

        <!-- Карточки -->
        <Grid Grid.Row="2"
              RowDefinitions="*,*"
              ColumnDefinitions="*,*"
              RowSpacing="16"
              ColumnSpacing="16">

          <!-- ЛОКАЛЬНЫЙ ДУБЛЯЖ -->
          <Border Background="#0F172A" CornerRadius="16" Padding="20">
            <StackPanel Spacing="12">

              <TextBlock Text="Локальный дубляж"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="White"/>

              <TextBlock Text="Загрузка видео с компьютера и запуск обработки."
                         Foreground="#94A3B8"
                         TextWrapping="Wrap"/>

              <Button Content="Открыть"
                      Click="OpenLocalUpload"
                      Background="#1D4ED8"
                      Foreground="White"
                      Padding="12,6"/>

            </StackPanel>
          </Border>

          <!-- ССЫЛКА -->
          <Border Grid.Column="1"
                  Background="#0F172A"
                  CornerRadius="16"
                  Padding="20">
            <StackPanel Spacing="12">

              <TextBlock Text="Загрузка по ссылке"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="White"/>

              <TextBlock Text="Обработка видео по URL."
                         Foreground="#94A3B8"
                         TextWrapping="Wrap"/>

              <Button Content="Открыть"
                      Click="OpenNetworkUpload"
                      Background="#1D4ED8"
                      Foreground="White"
                      Padding="12,6"/>

            </StackPanel>
          </Border>

          <!-- АКТИВНЫЕ ДУБЛЯЖИ -->
          <Border Grid.Row="1"
                  Background="#0F172A"
                  CornerRadius="16"
                  Padding="20">
            <StackPanel Spacing="12">

              <TextBlock Text="Активные дубляжи"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="White"/>

              <TextBlock Text="Список текущих обработок с прогрессом."
                         Foreground="#94A3B8"
                         TextWrapping="Wrap"/>

              <Button Content="Перейти"
                      Click="OpenActiveOrders"
                      Background="#475569"
                      Foreground="White"
                      Padding="12,6"/>

            </StackPanel>
          </Border>

          <!-- ИСТОРИЯ -->
          <Border Grid.Row="1"
                  Grid.Column="1"
                  Background="#0F172A"
                  CornerRadius="16"
                  Padding="20">
            <StackPanel Spacing="12">

              <TextBlock Text="История дубляжей"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="White"/>

              <TextBlock Text="Все завершённые дубляжи с возможностью просмотра."
                         Foreground="#94A3B8"
                         TextWrapping="Wrap"/>

              <Button Content="Открыть"
                      Click="OpenHistory"
                      Background="#475569"
                      Foreground="White"
                      Padding="12,6"/>

            </StackPanel>
          </Border>

        </Grid>
          <!-- Logout -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

          <Button x:Name="BtnLogout"
                  Content="Выход"
                  Click="Logout"
                  Background="#B91C1C"
                  Foreground="White"
                  Padding="14,8"/>
        </StackPanel>

      </Grid>
    </Border>

  </Grid>
</Window>