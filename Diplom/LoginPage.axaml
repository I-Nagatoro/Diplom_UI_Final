<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Diplom.LoginPage"
        Width="430"
        Height="520"
        Title="Вход"
        Background="#0F172A"
        WindowStartupLocation="CenterScreen">

  <Border Background="#111827"
          CornerRadius="18"
          Padding="24"
          Margin="20">

    <StackPanel Spacing="14">

      <TextBlock Text="Вход"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="White"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,6"/>

      <TextBlock Text="Введите данные для авторизации"
                 Foreground="#CBD5E1"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 Margin="0,0,0,10"/>

      <TextBlock Text="Логин" Foreground="#CBD5E1"/>
      <TextBox x:Name="LoginBox" Watermark="Введите логин"/>

      <TextBlock Text="Пароль" Foreground="#CBD5E1"/>
      <TextBox x:Name="PasswordBox"/>

      <Button Content="Войти"
              Click="Login"
              Background="#059669"
              Foreground="White"
              Padding="14,8"
              Margin="0,8,0,0"/>

      <Button Content="Назад"
              Click="GoBack"
              Background="#475569"
              Foreground="White"
              Padding="14,8"/>

      <TextBlock x:Name="StatusText"
                 Foreground="#F87171"
                 FontWeight="SemiBold"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 Margin="0,8,0,0"/>

    </StackPanel>
  </Border>
</Window>